# App
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://app:app@localhost:5432/webhook_dashboard_alerts?schema=public

# Clerk (from https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/events
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/events

# Webhook verification
WEBHOOK_GENERIC_SECRET=dev_generic_secret
WEBHOOK_STRIPE_LIKE_SECRET=dev_stripe_like_secret
WEBHOOK_ALLOW_UNSIGNED_GENERIC=false
WEBHOOK_RATE_LIMIT_MAX=60
WEBHOOK_RATE_LIMIT_WINDOW_MS=60000

# Admin bootstrapping
ADMIN_EMAIL=admin@example.com

# Local-only bypass for smoke tests (never enable in prod)
DEV_BYPASS_AUTH=false
